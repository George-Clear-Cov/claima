generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  name           String
  hashedPassword String
  practiceId     String
  role           UserRole @default(BILLER)
  createdAt      DateTime @default(now())

  practice Practice @relation(fields: [practiceId], references: [id])
}

enum UserRole {
  ADMIN
  BILLER
}

model Practice {
  id                String   @id @default(uuid())
  name              String
  npi               String   @unique
  taxId             String
  taxonomy          String
  addressLine1      String
  addressLine2      String?
  city              String
  state             String
  zip               String
  phone             String
  stripeAccountId   String?  // Stripe Connect connected account ID
  stripeOnboarded   Boolean  @default(false)
  platformFeePercent Float   @default(5.0) // MediBill platform fee %
  createdAt         DateTime @default(now())

  providers Provider[]
  patients  Patient[]
  claims    Claim[]
  users     User[]
}

model Provider {
  id         String   @id @default(uuid())
  practiceId String
  firstName  String
  lastName   String
  npi        String   @unique
  taxonomy   String
  createdAt  DateTime @default(now())

  practice Practice @relation(fields: [practiceId], references: [id])
  claims   Claim[]
}

model Patient {
  id           String   @id @default(uuid())
  practiceId   String
  firstName    String
  lastName     String
  dob          DateTime
  gender       String
  memberId     String
  groupNumber  String?
  payerId      String
  payerName    String
  addressLine1 String
  city         String
  state        String
  zip          String
  createdAt    DateTime @default(now())

  practice          Practice           @relation(fields: [practiceId], references: [id])
  claims            Claim[]
  eligibilityChecks EligibilityCheck[]
  statements        PatientStatement[]
}

model Claim {
  id            String      @id @default(uuid())
  practiceId    String
  providerId    String
  patientId     String
  serviceDate   DateTime
  claimStatus   ClaimStatus @default(DRAFT)
  totalCharge   Decimal     @db.Decimal(10, 2)
  stediClaimId  String?
  stediResponse Json?
  denialCode    String?
  denialReason  String?
  submittedAt   DateTime?
  paidAmount    Decimal?    @db.Decimal(10, 2)
  paidAt        DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  practice   Practice          @relation(fields: [practiceId], references: [id])
  provider   Provider          @relation(fields: [providerId], references: [id])
  patient    Patient           @relation(fields: [patientId], references: [id])
  lineItems  ClaimLine[]
  denial     Denial?
  statement  PatientStatement?
}

model Denial {
  id             String       @id @default(uuid())
  claimId        String       @unique
  carcCode       String
  denialReason   String
  category       String
  priority       String
  action         String
  appealable     Boolean
  appealStatus   AppealStatus @default(PENDING)
  appealLetter   String?
  appealedAt     DateTime?
  resolvedAt     DateTime?
  resolution     String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  claim Claim @relation(fields: [claimId], references: [id])
}

model PatientStatement {
  id               String          @id @default(uuid())
  patientId        String
  claimId          String          @unique
  totalCharge      Decimal         @db.Decimal(10, 2)
  insurancePaid    Decimal         @db.Decimal(10, 2)
  adjustments      Decimal         @db.Decimal(10, 2) @default(0)
  patientOwes      Decimal         @db.Decimal(10, 2)
  patientPaid      Decimal         @db.Decimal(10, 2) @default(0)
  balanceDue       Decimal         @db.Decimal(10, 2)
  statementStatus  StatementStatus @default(PENDING)
  dueDate          DateTime?
  paidAt           DateTime?
  notes            String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  patient Patient @relation(fields: [patientId], references: [id])
  claim   Claim   @relation(fields: [claimId], references: [id])
}

enum StatementStatus {
  PENDING
  SENT
  PARTIAL
  PAID
  WRITE_OFF
  COLLECTIONS
}

enum AppealStatus {
  PENDING
  IN_PROGRESS
  SUBMITTED
  WON
  LOST
  WRITE_OFF
}

model EligibilityCheck {
  id               String   @id @default(uuid())
  patientId        String
  payerId          String
  memberId         String
  eligible         Boolean
  coverageActive   Boolean
  planName         String?
  groupNumber      String?
  deductible       Decimal? @db.Decimal(10, 2)
  deductibleMet    Decimal? @db.Decimal(10, 2)
  outOfPocketMax   Decimal? @db.Decimal(10, 2)
  outOfPocketMet   Decimal? @db.Decimal(10, 2)
  copay            Decimal? @db.Decimal(10, 2)
  coinsurance      Int?
  visitLimit       Int?
  visitsUsed       Int?
  priorAuthRequired Boolean @default(false)
  inNetwork        Boolean  @default(true)
  effectiveDate    String?
  terminationDate  String?
  rawResponse      Json?
  checkedAt        DateTime @default(now())

  patient Patient @relation(fields: [patientId], references: [id])
}

model ClaimLine {
  id           String   @id @default(uuid())
  claimId      String
  cptCode      String
  icd10Codes   String[]
  modifier     String?
  units        Int      @default(1)
  chargeAmount Decimal  @db.Decimal(10, 2)
  description  String?

  claim Claim @relation(fields: [claimId], references: [id])
}

enum ClaimStatus {
  DRAFT
  SUBMITTED
  ACCEPTED
  REJECTED
  DENIED
  PAID
}
