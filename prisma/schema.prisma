generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String    @id @default(uuid())
  email                String    @unique
  name                 String
  hashedPassword       String
  practiceId           String
  role                 UserRole  @default(BILLER)
  failedLoginAttempts  Int       @default(0)
  lockedUntil          DateTime?
  createdAt            DateTime  @default(now())

  practice Practice @relation(fields: [practiceId], references: [id])
}

enum UserRole {
  ADMIN
  BILLER
}

model Practice {
  id                String   @id @default(uuid())
  name              String
  npi               String   @unique
  taxId             String
  taxonomy          String
  addressLine1      String
  addressLine2      String?
  city              String
  state             String
  zip               String
  phone             String
  stripeAccountId   String?
  stripeOnboarded   Boolean  @default(false)
  platformFeePercent Float   @default(5.0)
  baaAcceptedAt     DateTime?
  baaAcceptedIp     String?
  createdAt         DateTime @default(now())

  providers               Provider[]
  patients                Patient[]
  claims                  Claim[]
  users                   User[]
  marketplaceSubscriptions MarketplaceSubscription[]
  eras                    ERA[]
  payerEnrollments        PracticePayerEnrollment[]
  priorAuths              PriorAuthorization[]
  ccmTimeLogs             CcmTimeLog[]
  providerCredentials     ProviderCredential[]
  oigChecks               OigCheck[]
  aiUsage                 AiUsage[]
}

model AiUsage {
  id            String   @id @default(uuid())
  practiceId    String
  day           String   // YYYY-MM-DD (UTC) — daily bucket
  calls         Int      @default(0)
  inputTokens   Int      @default(0)
  outputTokens  Int      @default(0)
  estCostMicros Int      @default(0) // estimated cost in micro-USD (1e-6 USD)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  practice      Practice @relation(fields: [practiceId], references: [id])

  @@unique([practiceId, day])
  @@index([practiceId, day])
}

model Provider {
  id                   String    @id @default(uuid())
  practiceId           String
  firstName            String
  lastName             String
  npi                  String    @unique
  taxonomy             String
  deaNumber            String?
  deaExpiry            DateTime?
  stateLicense         String?
  stateLicenseState    String?
  stateLicenseExpiry   DateTime?
  boardCertExpiry      DateTime?
  malpracticeCarrier   String?
  malpracticeExpiry    DateTime?
  caqhProviderId       String?
  caqhLastUpdated      DateTime?
  createdAt            DateTime  @default(now())

  practice            Practice             @relation(fields: [practiceId], references: [id])
  claims              Claim[]
  payerCredentials    ProviderCredential[]
  oigChecks           OigCheck[]
}

model ProviderCredential {
  id              String           @id @default(uuid())
  practiceId      String
  providerId      String
  payerId         String
  payerName       String
  status          CredentialStatus @default(PENDING)
  applicationDate DateTime?
  approvedDate    DateTime?
  expiryDate      DateTime?
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  practice Practice @relation(fields: [practiceId], references: [id])
  provider Provider @relation(fields: [providerId], references: [id])

  @@unique([providerId, payerId])
  @@index([practiceId])
}

enum CredentialStatus {
  PENDING
  IN_REVIEW
  APPROVED
  DENIED
  EXPIRED
  RE_CREDENTIALING
}

model Patient {
  id                       String   @id @default(uuid())
  practiceId               String
  firstName                String
  lastName                 String
  dob                      DateTime
  gender                   String
  memberId                 String
  groupNumber              String?
  payerId                  String
  payerName                String
  relationshipToSubscriber String   @default("18")
  addressLine1             String
  city                     String
  state                    String
  zip                      String
  email                    String?
  phone                    String?
  ccmEnrolled              Boolean  @default(false)
  ccmEnrolledAt            DateTime?
  ccmConsentedAt           DateTime?
  createdAt                DateTime @default(now())

  practice          Practice           @relation(fields: [practiceId], references: [id])
  claims            Claim[]
  eligibilityChecks EligibilityCheck[]
  statements        PatientStatement[]
  priorAuths        PriorAuthorization[]
  ccmTimeLogs       CcmTimeLog[]
}

model Claim {
  id                   String      @id @default(uuid())
  practiceId           String
  providerId           String
  patientId            String
  serviceDate          DateTime
  claimStatus          ClaimStatus @default(DRAFT)
  totalCharge          Decimal     @db.Decimal(10, 2)
  placeOfService       String      @default("11")
  referringProviderNpi String?
  priorAuthId          String?
  stediClaimId         String?
  stediResponse        Json?
  denialCode           String?
  denialReason         String?
  submittedAt          DateTime?
  paidAmount           Decimal?    @db.Decimal(10, 2)
  paidAt               DateTime?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  practice   Practice               @relation(fields: [practiceId], references: [id])
  provider   Provider               @relation(fields: [providerId], references: [id])
  patient    Patient                @relation(fields: [patientId], references: [id])
  priorAuth  PriorAuthorization?    @relation(fields: [priorAuthId], references: [id])
  lineItems  ClaimLine[]
  denial     Denial?
  statement  PatientStatement?
  era        ERA?
}

model Denial {
  id             String       @id @default(uuid())
  claimId        String       @unique
  carcCode       String
  denialReason   String
  category       String
  priority       String
  action         String
  appealable     Boolean
  appealStatus   AppealStatus @default(PENDING)
  appealLetter   String?
  appealedAt     DateTime?
  resolvedAt     DateTime?
  resolution     String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  claim Claim @relation(fields: [claimId], references: [id])
}

model PatientStatement {
  id               String          @id @default(uuid())
  patientId        String
  claimId          String          @unique
  totalCharge      Decimal         @db.Decimal(10, 2)
  insurancePaid    Decimal         @db.Decimal(10, 2)
  adjustments      Decimal         @db.Decimal(10, 2) @default(0)
  patientOwes      Decimal         @db.Decimal(10, 2)
  patientPaid      Decimal         @db.Decimal(10, 2) @default(0)
  balanceDue       Decimal         @db.Decimal(10, 2)
  statementStatus  StatementStatus @default(PENDING)
  dueDate          DateTime?
  paidAt           DateTime?
  outreachSentAt   DateTime?
  outreachCount    Int             @default(0)
  notes            String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  patient Patient @relation(fields: [patientId], references: [id])
  claim   Claim   @relation(fields: [claimId], references: [id])
}

enum StatementStatus {
  PENDING
  SENT
  PARTIAL
  PAID
  WRITE_OFF
  COLLECTIONS
}

enum AppealStatus {
  PENDING
  IN_PROGRESS
  SUBMITTED
  WON
  LOST
  WRITE_OFF
}

model EligibilityCheck {
  id               String   @id @default(uuid())
  patientId        String
  payerId          String
  memberId         String
  eligible         Boolean
  coverageActive   Boolean
  planName         String?
  groupNumber      String?
  deductible       Decimal? @db.Decimal(10, 2)
  deductibleMet    Decimal? @db.Decimal(10, 2)
  outOfPocketMax   Decimal? @db.Decimal(10, 2)
  outOfPocketMet   Decimal? @db.Decimal(10, 2)
  copay            Decimal? @db.Decimal(10, 2)
  coinsurance      Int?
  visitLimit       Int?
  visitsUsed       Int?
  priorAuthRequired Boolean @default(false)
  inNetwork        Boolean  @default(true)
  effectiveDate    String?
  terminationDate  String?
  rawResponse      Json?
  checkedAt        DateTime @default(now())

  patient Patient @relation(fields: [patientId], references: [id])
}

model ClaimLine {
  id           String   @id @default(uuid())
  claimId      String
  cptCode      String
  icd10Codes   String[]
  modifier     String?
  units        Int      @default(1)
  chargeAmount Decimal  @db.Decimal(10, 2)
  description  String?

  claim Claim @relation(fields: [claimId], references: [id])
}

enum ClaimStatus {
  DRAFT
  SUBMITTED
  ACCEPTED
  REJECTED
  DENIED
  PAID
}

model AuditLog {
  id         String   @id @default(uuid())
  practiceId String?
  userId     String?
  userEmail  String?
  action     String
  resource   String?
  resourceId String?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([practiceId, createdAt])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
}

model ERA {
  id                    String    @id @default(cuid())
  practiceId            String
  claimId               String?   @unique
  claimMdEraId          String
  checkNumber           String?
  payerId               String
  payerName             String
  claimMdClaimId        String?
  patientFirstName      String?
  patientLastName       String?
  serviceDate           DateTime?
  chargeAmount          Decimal?  @db.Decimal(10, 2)
  insurancePaid         Decimal   @db.Decimal(10, 2)
  adjustments           Decimal   @db.Decimal(10, 2)
  patientResponsibility Decimal   @db.Decimal(10, 2)
  carcCodes             String[]
  rawData               Json
  matchedAt             DateTime?
  processedAt           DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  practice Practice @relation(fields: [practiceId], references: [id])
  claim    Claim?   @relation(fields: [claimId], references: [id])

  @@index([practiceId, createdAt])
}

model PracticePayerEnrollment {
  id               String           @id @default(cuid())
  practiceId       String
  payerId          String
  payerName        String
  enrollmentStatus EnrollmentStatus @default(PENDING)
  claimMdPayerId   String?
  enrolledAt       DateTime?
  notes            String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  practice Practice @relation(fields: [practiceId], references: [id])

  @@unique([practiceId, payerId])
}

enum EnrollmentStatus {
  PENDING
  ACTIVE
  INACTIVE
}

model MarketplaceSubscription {
  id             String    @id @default(uuid())
  practiceId     String?
  marketplace    String
  externalId     String    @unique
  productCode    String?
  planId         String?
  status         String
  quantity       Int       @default(1)
  activatedAt    DateTime?
  cancelledAt    DateTime?
  rawPayload     Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  practice Practice? @relation(fields: [practiceId], references: [id])

  @@index([marketplace, externalId])
}

enum PAStatus {
  PENDING
  APPROVED
  DENIED
  EXPIRED
  CANCELLED
}

model PriorAuthorization {
  id               String    @id @default(uuid())
  practiceId       String
  patientId        String
  payerId          String
  payerName        String
  cptCodes         String[]
  authNumber       String?
  status           PAStatus  @default(PENDING)
  requestedAt      DateTime  @default(now())
  approvedAt       DateTime?
  expiresAt        DateTime?
  sessionsApproved Int?
  sessionsUsed     Int       @default(0)
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  practice Practice @relation(fields: [practiceId], references: [id])
  patient  Patient  @relation(fields: [patientId], references: [id])
  claims   Claim[]

  @@index([practiceId])
  @@index([patientId])
}

enum OigStatus {
  CLEAR
  EXCLUDED
  ERROR
}

model OigCheck {
  id           String    @id @default(uuid())
  practiceId   String
  providerId   String
  checkedAt    DateTime  @default(now())
  status       OigStatus @default(CLEAR)
  matchFound   Boolean   @default(false)
  matchDetails Json?
  error        String?

  practice Practice @relation(fields: [practiceId], references: [id])
  provider Provider @relation(fields: [providerId], references: [id])

  @@index([practiceId])
  @@index([providerId, checkedAt])
}

model CcmTimeLog {
  id          String   @id @default(uuid())
  practiceId  String
  patientId   String
  logDate     DateTime @default(now())
  minutes     Int
  description String?
  createdAt   DateTime @default(now())

  practice Practice @relation(fields: [practiceId], references: [id])
  patient  Patient  @relation(fields: [patientId], references: [id])

  @@index([practiceId])
  @@index([patientId, logDate])
}
